---
import '@/styles/global.css';

const {
  title,
  description = 'Software engineering interview notes organized by topic and question.',
  image = '/favicon.svg',
  showSearchAction = false
} = Astro.props;
const canonicalUrl = Astro.url;
const imageUrl = new URL(image, canonicalUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:site_name" content="Interview" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={imageUrl.href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl.href} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('theme-preference') || 'auto';
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          }
        } catch {
          document.documentElement.removeAttribute('data-theme');
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Interview Question Sessions</a>
      <div class="header-actions">
        <nav aria-label="Primary navigation">
          <a href="/">Index</a>
        </nav>
        <div class="theme-toggle" aria-label="Color theme">
          <button type="button" data-theme-option="auto" aria-pressed="true">Auto</button>
          <button type="button" data-theme-option="light" aria-pressed="false">Light</button>
          <button type="button" data-theme-option="dark" aria-pressed="false">Dark</button>
        </div>
        <div class="mobile-header-actions">
          {showSearchAction && (
            <button class="mobile-icon-button" type="button" aria-label="Search" aria-expanded="false" data-mobile-search>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m21 21-4.3-4.3" />
                <circle cx="11" cy="11" r="7" />
              </svg>
            </button>
          )}
          <button
            class="mobile-icon-button"
            type="button"
            aria-label="Open navigation"
            aria-controls="docs-navigation"
            aria-expanded="false"
            data-mobile-menu
            hidden
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
    </header>
    <button class="mobile-nav-backdrop" type="button" aria-label="Close navigation" data-mobile-nav-backdrop></button>
    {showSearchAction && (
      <div class="mobile-search-panel" data-mobile-search-panel hidden>
        <label class="search-label" for="mobile-note-search">Search subtopics</label>
        <input id="mobile-note-search" type="search" placeholder="Filter by topic, subtopic, or question" autocomplete="off" data-mobile-search-input />
      </div>
    )}
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; Selçuk Cihan</p>
      <a href="https://github.com/selcukcihan/interview" rel="noreferrer">selcukcihan/interview</a>
    </footer>
    <script is:inline>
      (() => {
        const storageKey = 'theme-preference';
        const buttons = [...document.querySelectorAll('[data-theme-option]')];

        function applyTheme(theme) {
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          } else {
            document.documentElement.removeAttribute('data-theme');
          }

          buttons.forEach((button) => {
            button.setAttribute('aria-pressed', String(button.dataset.themeOption === theme));
          });
        }

        function getSavedTheme() {
          try {
            return localStorage.getItem(storageKey) || 'auto';
          } catch {
            return 'auto';
          }
        }

        function saveTheme(theme) {
          try {
            localStorage.setItem(storageKey, theme);
          } catch {
            return;
          }
        }

        const savedTheme = getSavedTheme();
        applyTheme(savedTheme);

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const theme = button.dataset.themeOption || 'auto';
            saveTheme(theme);
            applyTheme(theme);
          });
        });
      })();
    </script>
    <script is:inline>
      (() => {
        const menuButton = document.querySelector('[data-mobile-menu]');
        const backdrop = document.querySelector('[data-mobile-nav-backdrop]');
        const sidebar = document.querySelector('.docs-sidebar');
        const searchButton = document.querySelector('[data-mobile-search]');
        const searchPanel = document.querySelector('[data-mobile-search-panel]');
        const mobileSearchInput = document.querySelector('[data-mobile-search-input]');

        if (!menuButton || !backdrop) return;

        menuButton.hidden = !sidebar;

        function setOpen(isOpen) {
          document.body.classList.toggle('mobile-nav-open', isOpen);
          menuButton.setAttribute('aria-expanded', String(isOpen));
        }

        menuButton.addEventListener('click', () => {
          setOpen(!document.body.classList.contains('mobile-nav-open'));
        });

        backdrop.addEventListener('click', () => setOpen(false));

        sidebar?.addEventListener('click', (event) => {
          if (event.target instanceof HTMLAnchorElement) {
            setOpen(false);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            setOpen(false);
            closeSearch();
          }
        });

        function closeSearch() {
          if (searchPanel instanceof HTMLElement) {
            searchPanel.hidden = true;
          }

          searchButton?.setAttribute('aria-expanded', 'false');
        }

        searchButton?.addEventListener('click', () => {
          setOpen(false);

          if (searchPanel instanceof HTMLElement) {
            searchPanel.hidden = !searchPanel.hidden;
          }

          const isOpen = searchPanel instanceof HTMLElement && !searchPanel.hidden;
          searchButton.setAttribute('aria-expanded', String(isOpen));

          if (isOpen && mobileSearchInput instanceof HTMLInputElement) {
            mobileSearchInput.focus();
            mobileSearchInput.select();
          }
        });
      })();
    </script>
  </body>
</html>
